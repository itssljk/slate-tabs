{
  "manifest_version": 3,
  "name": "Slate Tabs",
  "browser_specific_settings": {
    "gecko": {
      "id": "slate-tabs@itssljk"
    }
  },
  "version": "1.0.0",
  "description": "A clean, minimal, and ambient-themed browser start page with dynamic greetings, quick search, and custom controls.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://en.wikipedia.org/*",
    "https://api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "icons": {
    "16": "favicon.ico",
    "48": "icon.png",
    "128": "icon.png"
  }
}
